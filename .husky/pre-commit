pnpm exec lint-staged
pnpm run check:boundaries:staged
# pnpm run check:design-system:staged  # disabled — design system not ready yet
pnpm run check:i18n
pnpm run check:i18n:values
pnpm run check:i18n:interpolation
# check:i18n:unused scans all source files — only run when i18n files are staged
if git diff --cached --name-only | grep -qE '^src/i18n/'; then
  pnpm run check:i18n:unused
fi
pnpm run check:exhaustiveness
# pnpm run test:affected  # disabled — too slow for pre-commit, run manually or in CI
pnpm run check:component-structure
pnpm run check:missing-tests
pnpm run check:readme-reminders
