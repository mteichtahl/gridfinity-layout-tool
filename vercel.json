{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "ignoreCommand": "bash scripts/vercel-ignore.sh",
  "trailingSlash": false,
  "crons": [
    {
      "path": "/api/slicer-cleanup",
      "schedule": "0 * * * *"
    }
  ],
  "redirects": [
    { "source": "/generator", "destination": "/gridfinity-bin-generator", "permanent": true },
    { "source": "/sizes", "destination": "/gridfinity-sizes", "permanent": true }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "Cross-Origin-Opener-Policy", "value": "same-origin" },
        { "key": "Cross-Origin-Embedder-Policy", "value": "credentialless" }
      ]
    },
    {
      "source": "/api/(.*)",
      "headers": [
        { "key": "Access-Control-Allow-Origin", "value": "https://gridfinitylayouttool.com" },
        { "key": "Access-Control-Allow-Methods", "value": "GET, POST, PUT, DELETE" },
        { "key": "Access-Control-Allow-Headers", "value": "Content-Type, x-delete-token" }
      ]
    },
    {
      "source": "/storage-bridge.html",
      "headers": [
        { "key": "Cache-Control", "value": "public, max-age=0, must-revalidate" },
        { "key": "Cross-Origin-Resource-Policy", "value": "cross-origin" },
        {
          "key": "Content-Security-Policy",
          "value": "frame-ancestors https://www.gridfinitylayouttool.com"
        }
      ]
    },
    {
      "source": "/what-is-gridfinity",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/guide",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/privacy",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/terms",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/gridfinity-bin-generator",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/gridfinity-sizes",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=3600, stale-while-revalidate=86400"
        }
      ]
    },
    {
      "source": "/content.:hash.css",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/sw.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/workbox-:hash.js",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    },
    {
      "source": "/manifest.webmanifest",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/index.html",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=0, must-revalidate"
        }
      ]
    },
    {
      "source": "/assets/:path*",
      "headers": [
        {
          "key": "Cache-Control",
          "value": "public, max-age=31536000, immutable"
        }
      ]
    }
  ],
  "rewrites": [
    {
      "source": "/ph/static/:path(.*)",
      "destination": "https://us-assets.i.posthog.com/static/:path"
    },
    {
      "source": "/ph/:path(.*)",
      "destination": "https://us.i.posthog.com/:path"
    },
    { "source": "/what-is-gridfinity", "destination": "/what-is-gridfinity/index.html" },
    { "source": "/guide", "destination": "/guide/index.html" },
    { "source": "/privacy", "destination": "/privacy/index.html" },
    { "source": "/terms", "destination": "/terms/index.html" },
    {
      "source": "/gridfinity-bin-generator",
      "destination": "/gridfinity-bin-generator/index.html"
    },
    { "source": "/gridfinity-sizes", "destination": "/gridfinity-sizes/index.html" },
    { "source": "/s/:id([a-zA-Z0-9]{12})", "destination": "/" },
    { "source": "/l/:id([a-zA-Z0-9]{12})", "destination": "/" },
    { "source": "/l/:id([a-zA-Z0-9]{12})/:slug*", "destination": "/" },
    {
      "source": "/l/:uuid([0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})",
      "destination": "/"
    },
    {
      "source": "/l/:uuid([0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12})/:slug*",
      "destination": "/"
    }
  ]
}
