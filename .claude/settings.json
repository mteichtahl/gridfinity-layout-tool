{
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/post-edit-test.sh",
            "timeout": 60
          },
          {
            "type": "command",
            "command": ".claude/hooks/use-shallow-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/effect-cleanup-check.sh",
            "timeout": 10
          },
          {
            "type": "command",
            "command": ".claude/hooks/auto-format.sh",
            "timeout": 15
          },
          {
            "type": "command",
            "command": ".claude/hooks/geometry-sanity-check.sh",
            "timeout": 10
          }
        ]
      }
    ],
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/a11y-check.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/coverage-check.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/suppression-guard.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/dangerous-patterns.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/result-exhaustion-check.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/union-exhaustiveness-check.sh",
            "timeout": 30
          },
          {
            "type": "command",
            "command": ".claude/hooks/pre-pr-review.sh",
            "timeout": 60
          }
        ]
      }
    ]
  }
}
