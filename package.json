{
  "name": "gridfinity-layout-tool",
  "private": true,
  "version": "4.47.6",
  "description": "A web app for designing and planning Gridfinity drawer organizer layouts",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@10.30.0",
  "repository": {
    "type": "git",
    "url": "https://github.com/andymai/gridfinity-layout-tool.git"
  },
  "homepage": "https://gridfinitylayouttool.com",
  "author": "Andy Aragon",
  "keywords": [
    "gridfinity",
    "3d-printing",
    "drawer-organizer",
    "layout-tool",
    "react",
    "threejs"
  ],
  "scripts": {
    "dev": "pnpm run build:content && pnpm run build:en-locale && vite",
    "build": "pnpm run build:content && pnpm run build:en-locale && tsc -b && vite build",
    "build:content": "tsx scripts/build-content.ts",
    "build:en-locale": "tsx scripts/build-en-locale.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:affected": "./scripts/test-affected.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "test:visual:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "prepare": "husky",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "check:boundaries": "./scripts/check-module-boundaries.sh",
    "check:boundaries:staged": "./scripts/check-module-boundaries.sh --staged",
    "check:i18n": "tsx scripts/check-i18n-keys.ts",
    "check:i18n:interpolation": "tsx scripts/check-i18n-interpolation.ts",
    "check:i18n:unused": "tsx scripts/check-i18n-unused.ts",
    "check:i18n:values": "tsx scripts/check-i18n-values.ts",
    "check:exhaustiveness": "./scripts/check-union-exhaustiveness.sh",
    "check:design-system": "./scripts/check-design-system-usage.sh",
    "check:design-system:staged": "./scripts/check-design-system-usage.sh --staged",
    "check:readme-reminders": "./scripts/check-readme-reminders.sh",
    "check:missing-tests": "./scripts/check-missing-tests.sh",
    "check:component-structure": "./scripts/check-component-structure.sh",
    "bench": "vitest bench",
    "bench:json": "vitest bench --outputJson benchmarks/latest.json",
    "test:mutation": "stryker run",
    "test:mutation:changed": "stryker run --since=main",
    "test:mutation:file": "stryker run --mutate",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "typecheck": "tsc -b --noEmit",
    "quality": "pnpm run typecheck && pnpm run lint && pnpm run knip",
    "test:profile": "pnpm run build:en-locale && tsx scripts/profile-tests.ts"
  },
  "size-limit": [
    {
      "name": "Main bundle (gzip)",
      "path": "dist/assets/main-*.js",
      "gzip": true,
      "limit": "190 kB"
    },
    {
      "name": "Total JS (gzip)",
      "path": "dist/assets/*.js",
      "gzip": true,
      "limit": "1355 kB"
    }
  ],
  "dependencies": {
    "@gridfinity/branded-types": "workspace:*",
    "@liveblocks/client": "^3.18.4",
    "@liveblocks/node": "^3.18.4",
    "@liveblocks/react": "^3.18.4",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.0",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.3.3",
    "brepjs": "15.2.11",
    "brepjs-opencascade": "0.15.6",
    "brepkit-wasm": "^2.43.10",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fflate": "^0.8.2",
    "idb": "^8.0.3",
    "immer": "^11.1.4",
    "ioredis": "^5.10.1",
    "jszip": "^3.10.1",
    "lz-string": "^1.5.0",
    "posthog-js": "^1.369.3",
    "react": "^19.2.5",
    "react-dom": "^19.2.5",
    "svg-pathdata": "^9.0.0",
    "tailwind-merge": "^3.5.0",
    "three": "^0.184.0",
    "three-stdlib": "^2.36.1",
    "zod": "^4.3.6",
    "zustand": "^5.0.12"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "core-js",
      "esbuild",
      "protobufjs",
      "unrs-resolver"
    ],
    "overrides": {
      "@vercel/node>undici": "^7.20.0",
      "path-to-regexp": "6.3.0",
      "@rollup/plugin-replace>magic-string": "0.30.21",
      "@surma/rollup-plugin-off-main-thread>magic-string": "0.30.21",
      "workbox-build>@rollup/plugin-node-resolve": "^16.0.0",
      "@apideck/better-ajv-errors>ajv": "^8.17.1",
      "serialize-javascript": "^7.0.3",
      "eslint-plugin-react-hooks>eslint": "^10.0.3",
      "eslint-plugin-jsx-a11y>eslint": "^10.0.3",
      "eslint-plugin-jsx-a11y>minimatch": "^3.1.3",
      "@vercel/build-utils>minimatch": "^10.2.3",
      "@vercel/python-analysis>minimatch": "^10.2.3",
      "@vercel/static-config>ajv": "^8.18.0",
      "glob>minimatch": "^10.2.3",
      "flatted": "^3.4.2",
      "posthog-js>dompurify": "^3.4.0",
      "eslint-plugin-i18next>lodash": "^4.18.1",
      "vitest-axe>lodash-es": "^4.18.1",
      "picomatch@>=4.0.0 <4.0.4": "^4.0.4"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.2",
    "@eslint/compat": "^2.0.5",
    "@eslint/js": "^10.0.0",
    "@playwright/experimental-ct-react": "^1.59.1",
    "@playwright/test": "^1.59.1",
    "@size-limit/file": "^12.1.0",
    "@stryker-mutator/core": "^9.6.1",
    "@stryker-mutator/vitest-runner": "^9.6.1",
    "@tailwindcss/vite": "^4.2.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.6.0",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.184.0",
    "@vercel/node": "^5.7.12",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.1.4",
    "@vitest/ui": "^4.1.4",
    "axe-core": "^4.11.3",
    "eslint": "^10.2.0",
    "eslint-import-resolver-typescript": "^4.4.4",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.5.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^29.0.2",
    "knip": "^6.5.0",
    "lint-staged": "^16.3.1",
    "marked": "^18.0.2",
    "postcss": "^8.5.10",
    "prettier": "^3.8.2",
    "rollup-plugin-visualizer": "^7.0.0",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.2.2",
    "tsx": "^4.21.0",
    "typescript": "~6.0.2",
    "typescript-eslint": "^8.58.2",
    "vite": "^7.3.2",
    "vite-plugin-pwa": "^1.2.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.4",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.4.0"
  }
}
