{
  "name": "gridfinity-layout-tool",
  "private": true,
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "npm run build:content && vite",
    "build": "npm run build:content && tsc -b && vite build",
    "build:content": "tsx scripts/build-content.ts",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "size": "size-limit",
    "size:check": "size-limit --limit"
  },
  "size-limit": [
    {
      "name": "Main bundle (gzip)",
      "path": "dist/assets/index-*.js",
      "gzip": true,
      "limit": "126 kB"
    },
    {
      "name": "Total JS (gzip)",
      "path": "dist/assets/*.js",
      "gzip": true,
      "limit": "690 kB"
    }
  ],
  "dependencies": {
    "@liveblocks/client": "^3.13.0",
    "@liveblocks/node": "^3.13.0",
    "@liveblocks/react": "^3.13.0",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "idb": "^8.0.3",
    "immer": "^11.1.3",
    "ioredis": "^5.9.2",
    "lz-string": "^1.5.0",
    "posthog-js": "^1.318.1",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "three": "^0.182.0",
    "zustand": "^5.0.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@size-limit/file": "^12.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/lz-string": "^1.3.34",
    "@types/node": "^25.0.6",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.16",
    "autoprefixer": "^10.4.23",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.1",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.0.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "marked": "^17.0.1",
    "postcss": "^8.5.6",
    "size-limit": "^12.0.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0"
  }
}
