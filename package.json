{
  "name": "gridfinity-layout-tool",
  "private": true,
  "version": "4.1.2",
  "description": "A web app for designing and planning Gridfinity drawer organizer layouts",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/andymai/gridfinity-layout-tool.git"
  },
  "homepage": "https://gridfinitylayouttool.com",
  "author": "Andy Aragon",
  "keywords": [
    "gridfinity",
    "3d-printing",
    "drawer-organizer",
    "layout-tool",
    "react",
    "threejs"
  ],
  "scripts": {
    "dev": "npm run build:content && npm run build:en-locale && vite",
    "build": "npm run build:content && npm run build:en-locale && tsc -b && vite build",
    "build:content": "tsx scripts/build-content.ts",
    "build:en-locale": "tsx scripts/build-en-locale.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:affected": "./scripts/test-affected.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "test:visual:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "prepare": "husky",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "check:boundaries": "./scripts/check-module-boundaries.sh",
    "check:boundaries:staged": "./scripts/check-module-boundaries.sh --staged",
    "check:i18n": "tsx scripts/check-i18n-keys.ts",
    "check:i18n:interpolation": "tsx scripts/check-i18n-interpolation.ts",
    "check:i18n:unused": "tsx scripts/check-i18n-unused.ts",
    "check:i18n:values": "tsx scripts/check-i18n-values.ts",
    "check:exhaustiveness": "./scripts/check-union-exhaustiveness.sh",
    "check:design-system": "./scripts/check-design-system-usage.sh",
    "check:design-system:staged": "./scripts/check-design-system-usage.sh --staged",
    "check:readme-reminders": "./scripts/check-readme-reminders.sh",
    "check:missing-tests": "./scripts/check-missing-tests.sh",
    "check:component-structure": "./scripts/check-component-structure.sh",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "typecheck": "tsc -b --noEmit",
    "quality": "npm run typecheck && npm run lint && npm run knip"
  },
  "size-limit": [
    {
      "name": "Main bundle (gzip)",
      "path": "dist/assets/main-*.js",
      "gzip": true,
      "limit": "190 kB"
    },
    {
      "name": "Total JS (gzip)",
      "path": "dist/assets/*.js",
      "gzip": true,
      "limit": "1350 kB"
    }
  ],
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.61",
    "@liveblocks/client": "^3.14.1",
    "@liveblocks/node": "^3.14.1",
    "@liveblocks/react": "^3.14.1",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.3.0",
    "ai": "^6.0.108",
    "brepjs": "^9.3.9",
    "brepjs-opencascade": "^0.9.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fflate": "^0.8.2",
    "idb": "^8.0.3",
    "immer": "^11.1.4",
    "ioredis": "^5.10.0",
    "jszip": "^3.10.1",
    "lz-string": "^1.5.0",
    "posthog-js": "^1.357.1",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "tailwind-merge": "^3.5.0",
    "three": "^0.183.2",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "@vercel/node": {
      "undici": "^7.20.0"
    },
    "path-to-regexp": "6.3.0",
    "workbox-build": {
      "@rollup/plugin-replace": {
        "magic-string": "0.30.21"
      },
      "@surma/rollup-plugin-off-main-thread": {
        "magic-string": "0.30.21"
      },
      "@rollup/plugin-node-resolve": "^16.0.0",
      "@rollup/plugin-terser": "^0.4.4"
    },
    "@apideck/better-ajv-errors": {
      "ajv": "^8.17.1"
    },
    "serialize-javascript": "^7.0.3",
    "eslint-plugin-react-hooks": {
      "eslint": "$eslint"
    },
    "eslint-plugin-jsx-a11y": {
      "eslint": "$eslint",
      "minimatch": "^3.1.3"
    },
    "@ts-morph/common": {
      "minimatch": "^3.1.3"
    },
    "filelist": {
      "minimatch": "^5.1.8"
    },
    "@typescript-eslint/typescript-estree": {
      "minimatch": "^9.0.7"
    },
    "@vercel/build-utils": {
      "minimatch": "^10.2.3"
    },
    "glob": {
      "minimatch": "^10.2.3"
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.1",
    "@eslint/compat": "^2.0.2",
    "@eslint/js": "^10.0.0",
    "@playwright/experimental-ct-react": "^1.58.2",
    "@playwright/test": "^1.58.2",
    "@size-limit/file": "^12.0.0",
    "@tailwindcss/vite": "^4.2.1",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^25.3.3",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.183.1",
    "@vercel/node": "^5.6.10",
    "@vitejs/plugin-react": "^5.1.4",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.16",
    "axe-core": "^4.11.1",
    "eslint": "^10.0.2",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.5.1",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.4.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^28.1.0",
    "knip": "^5.85.0",
    "lint-staged": "^16.3.1",
    "marked": "^17.0.3",
    "postcss": "^8.5.8",
    "prettier": "^3.5.0",
    "rollup-plugin-visualizer": "^7.0.0",
    "size-limit": "^12.0.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.56.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0"
  }
}
