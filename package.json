{
  "name": "gridfinity-layout-tool",
  "private": true,
  "version": "2.0.2",
  "description": "A web app for designing and planning Gridfinity drawer organizer layouts",
  "license": "AGPL-3.0-only",
  "type": "module",
  "repository": {
    "type": "git",
    "url": "https://github.com/andymai/gridfinity-layout-tool.git"
  },
  "homepage": "https://gridfinitylayouttool.com",
  "author": "Andy Aragon",
  "keywords": [
    "gridfinity",
    "3d-printing",
    "drawer-organizer",
    "layout-tool",
    "react",
    "threejs"
  ],
  "scripts": {
    "dev": "npm run build:content && vite",
    "build": "npm run build:content && tsc -b && vite build",
    "build:content": "tsx scripts/build-content.ts",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:affected": "./scripts/test-affected.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "prepare": "husky",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "check:boundaries": "./scripts/check-module-boundaries.sh",
    "check:boundaries:staged": "./scripts/check-module-boundaries.sh --staged",
    "check:i18n": "tsx scripts/check-i18n-keys.ts",
    "check:i18n:interpolation": "tsx scripts/check-i18n-interpolation.ts",
    "check:exhaustiveness": "./scripts/check-union-exhaustiveness.sh",
    "check:missing-tests": "./scripts/check-missing-tests.sh"
  },
  "size-limit": [
    {
      "name": "Main bundle (gzip)",
      "path": "dist/assets/main-*.js",
      "gzip": true,
      "limit": "190 kB"
    },
    {
      "name": "Total JS (gzip)",
      "path": "dist/assets/*.js",
      "gzip": true,
      "limit": "1150 kB"
    }
  ],
  "dependencies": {
    "@ai-sdk/gateway": "^3.0.22",
    "@liveblocks/client": "^3.13.3",
    "@liveblocks/node": "^3.13.3",
    "@liveblocks/react": "^3.13.3",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.5.0",
    "@vercel/analytics": "^1.6.1",
    "@vercel/blob": "^2.0.0",
    "@vercel/speed-insights": "^1.3.1",
    "ai": "^6.0.49",
    "cmdk": "^1.1.1",
    "fflate": "^0.8.2",
    "idb": "^8.0.3",
    "immer": "^11.1.3",
    "ioredis": "^5.9.2",
    "lz-string": "^1.5.0",
    "posthog-js": "^1.334.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "replicad": "^0.20.5",
    "replicad-opencascadejs": "^0.20.2",
    "three": "^0.182.0",
    "zod": "^4.3.6",
    "zustand": "^5.0.9"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix --max-warnings=0",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "overrides": {
    "path-to-regexp": "6.3.0",
    "undici": "6.23.0",
    "workbox-build": {
      "@rollup/plugin-replace": {
        "magic-string": "0.30.21"
      },
      "@surma/rollup-plugin-off-main-thread": {
        "magic-string": "0.30.21"
      }
    }
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.11.0",
    "@eslint/js": "^9.39.1",
    "@playwright/test": "^1.57.0",
    "@size-limit/file": "^12.0.0",
    "@tailwindcss/vite": "^4.1.18",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@types/node": "^25.0.10",
    "@types/react": "^19.2.8",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.182.0",
    "@vercel/node": "^5.5.26",
    "@vitejs/plugin-react": "^5.1.1",
    "@vitest/coverage-v8": "^4.0.17",
    "@vitest/ui": "^4.0.16",
    "axe-core": "^4.11.1",
    "eslint": "^9.39.1",
    "eslint-plugin-i18next": "^6.1.3",
    "eslint-plugin-react-hooks": "^7.0.1",
    "eslint-plugin-react-refresh": "^0.4.24",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.0.0",
    "gray-matter": "^4.0.3",
    "husky": "^9.1.7",
    "jsdom": "^27.4.0",
    "lint-staged": "^16.2.7",
    "marked": "^17.0.1",
    "postcss": "^8.5.6",
    "prettier": "^3.5.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "size-limit": "^12.0.0",
    "tailwindcss": "^4.1.18",
    "tsx": "^4.21.0",
    "typescript": "~5.9.3",
    "typescript-eslint": "^8.53.0",
    "vite": "^7.3.1",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.16",
    "vitest-axe": "^0.1.0"
  }
}
