{
  "name": "gridfinity-layout-tool",
  "private": true,
  "version": "4.239.0",
  "description": "A web app for designing and planning Gridfinity drawer organizer layouts",
  "license": "AGPL-3.0-only",
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "engines": {
    "node": ">=24"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/andymai/gridfinity-layout-tool.git"
  },
  "homepage": "https://gridfinitylayouttool.com",
  "author": "Andy Aragon",
  "keywords": [
    "gridfinity",
    "3d-printing",
    "drawer-organizer",
    "layout-tool",
    "react",
    "threejs"
  ],
  "scripts": {
    "dev": "pnpm run build:content && pnpm run build:en-locale && vite",
    "build": "pnpm run build:content && pnpm run build:en-locale && tsgo -b && vite build && tsx scripts/build-route-entries.ts",
    "build:content": "tsx scripts/build-content.ts",
    "gen:seo-images": "tsx scripts/gen-seo-images.ts",
    "gen:supporters-meshes": "tsx --tsconfig tsconfig.app.json scripts/gen-supporters-meshes.ts",
    "build:en-locale": "tsx scripts/build-en-locale.ts",
    "lint": "NODE_OPTIONS=--max-old-space-size=8192 eslint . --cache --cache-location node_modules/.cache/eslint/",
    "lint:fix": "NODE_OPTIONS=--max-old-space-size=8192 eslint . --fix --cache --cache-location node_modules/.cache/eslint/",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "format:check": "prettier --check \"src/**/*.{ts,tsx,css}\" \"e2e/**/*.ts\" \"*.{json,md}\"",
    "preview": "vite preview",
    "test": "vitest",
    "test:run": "vitest run",
    "test:coverage": "vitest run --coverage",
    "test:affected": "./scripts/test-affected.sh",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:visual": "playwright test -c playwright-ct.config.ts",
    "test:visual:update": "playwright test -c playwright-ct.config.ts --update-snapshots",
    "prepare": "husky",
    "size": "size-limit",
    "size:check": "size-limit --limit",
    "check:boundaries": "./scripts/check-module-boundaries.sh",
    "check:boundaries:staged": "./scripts/check-module-boundaries.sh --staged",
    "check:i18n": "tsx scripts/check-i18n-keys.ts",
    "check:i18n:interpolation": "tsx scripts/check-i18n-interpolation.ts",
    "check:i18n:unused": "tsx scripts/check-i18n-unused.ts",
    "check:i18n:values": "tsx scripts/check-i18n-values.ts",
    "check:exhaustiveness": "./scripts/check-union-exhaustiveness.sh",
    "check:design-system": "./scripts/check-design-system-usage.sh",
    "check:design-system:staged": "./scripts/check-design-system-usage.sh --staged",
    "check:readme-reminders": "./scripts/check-readme-reminders.sh",
    "check:missing-tests": "./scripts/check-missing-tests.sh",
    "check:component-structure": "./scripts/check-component-structure.sh",
    "sync-admin": "tsx scripts/sync-admin/index.ts",
    "gen:example-thumbnails": "tsx --tsconfig tsconfig.app.json scripts/gen-example-thumbnails.ts",
    "bench": "vitest bench",
    "bench:json": "vitest bench --outputJson benchmarks/latest.json",
    "knip": "knip",
    "knip:fix": "knip --fix",
    "typecheck": "tsgo -b --noEmit",
    "quality": "pnpm run typecheck && pnpm run lint && pnpm run knip",
    "test:profile": "pnpm run build:en-locale && tsx scripts/profile-tests.ts"
  },
  "size-limit": [
    {
      "name": "Main bundle (gzip)",
      "path": "dist/assets/main-*.js",
      "gzip": true,
      "limit": "190 kB"
    },
    {
      "name": "Eager initial JS (gzip)",
      "path": [
        "dist/assets/main-*.js",
        "dist/assets/react-vendor-*.js",
        "dist/assets/state-*.js",
        "dist/assets/core-foundation-*.js"
      ],
      "gzip": true,
      "limit": "260 kB"
    },
    {
      "name": "Total JS (gzip, one locale)",
      "path": [
        "dist/assets/*.js",
        "!dist/assets/de-*.js",
        "!dist/assets/es-*.js",
        "!dist/assets/fr-*.js",
        "!dist/assets/ja-*.js",
        "!dist/assets/nb-*.js",
        "!dist/assets/nl-*.js",
        "!dist/assets/pt-BR-*.js",
        "!dist/assets/sv-*.js",
        "!dist/assets/uk-*.js"
      ],
      "gzip": true,
      "limit": "1900 kB"
    }
  ],
  "dependencies": {
    "@gridfinity/branded-types": "workspace:*",
    "@liveblocks/client": "^3.21.0",
    "@liveblocks/node": "^3.21.0",
    "@liveblocks/react": "^3.21.0",
    "@mediapipe/tasks-vision": "0.10.35",
    "@react-three/drei": "^10.7.7",
    "@react-three/fiber": "^9.6.1",
    "@vercel/analytics": "^2.0.1",
    "@vercel/blob": "^2.5.0",
    "arctic": "^3.7.0",
    "brepjs": "18.118.3",
    "brepkit-wasm": "^2.124.0",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "fflate": "^0.8.3",
    "fit-curve": "^0.2.0",
    "idb": "^8.0.3",
    "immer": "^11.1.8",
    "ioredis": "^5.11.1",
    "lz-string": "^1.5.0",
    "manifold-3d": "3.5.1",
    "occt-wasm": "3.6.1",
    "polygon-clipping": "^0.15.7",
    "posthog-js": "^1.396.2",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "svg-pathdata": "^9.0.0",
    "tailwind-merge": "^3.6.0",
    "three": "^0.185.0",
    "three-stdlib": "^2.36.1",
    "zod": "^4.4.3",
    "zustand": "^5.0.14"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{json,md,yml,yaml}": [
      "prettier --write"
    ]
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/compat": "^2.1.0",
    "@eslint/js": "^10.0.1",
    "@playwright/experimental-ct-react": "^1.61.0",
    "@playwright/test": "^1.61.0",
    "@size-limit/file": "^12.1.0",
    "@tailwindcss/vite": "^4.3.2",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@types/three": "^0.185.0",
    "@typescript/native-preview": "7.0.0-dev.20260707.2",
    "@vercel/node": "^5.8.22",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "@vitest/ui": "^4.1.9",
    "axe-core": "^4.12.1",
    "eslint": "^10.6.0",
    "eslint-import-resolver-typescript": "^4.4.5",
    "eslint-plugin-boundaries": "^6.0.2",
    "eslint-plugin-i18next": "^6.1.5",
    "eslint-plugin-jsx-a11y": "^6.10.2",
    "eslint-plugin-react-hooks": "~7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "fake-indexeddb": "^6.2.5",
    "globals": "^17.7.0",
    "gltf-pipeline": "^4.3.1",
    "husky": "^9.1.7",
    "js-yaml": "^5.2.0",
    "jsdom": "^29.1.1",
    "knip": "^6.23.0",
    "lint-staged": "^17.0.8",
    "marked": "^18.0.5",
    "postcss": "^8.5.16",
    "prettier": "^3.9.3",
    "rollup-plugin-visualizer": "^7.0.1",
    "size-limit": "^12.1.0",
    "tailwindcss": "^4.3.2",
    "tsx": "^4.22.4",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.0",
    "vite": "^8.1.0",
    "vite-plugin-pwa": "^1.3.0",
    "vite-plugin-wasm": "^3.6.0",
    "vitest": "^4.1.9",
    "vitest-axe": "^0.1.0",
    "workbox-window": "^7.4.1"
  }
}
