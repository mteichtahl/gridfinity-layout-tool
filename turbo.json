{
  "$schema": "https://turbo.build/schema.json",
  // ^typecheck is a no-op in a single-package repo today.
  // It's forward-looking: when workspace packages (e.g. branded-types)
  // are added, upstream typecheck will run before downstream tasks.
  "tasks": {
    "typecheck": { "dependsOn": ["^typecheck"] },
    "lint": { "dependsOn": ["^typecheck"] },
    "test": { "dependsOn": ["^typecheck"], "cache": false },
    "build": { "dependsOn": ["^typecheck"], "outputs": ["dist/**"] }
  }
}
